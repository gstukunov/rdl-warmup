# ============================================
# RDL Warmup Bot - Production Environment
# ============================================

# Server Configuration
NODE_ENV=production
PORT=3000

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=telegram_user
DB_PASSWORD=your_secure_db_password_here
DB_NAME=telegram_bot_db

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_USERNAME=your_bot_username
# IMPORTANT: This must be the public URL where your Mini App is accessible
# Format: https://your-domain.com/webapp
TELEGRAM_WEBAPP_URL=https://your-domain.com/webapp

# Game Configuration
GAME_PASSWORD=your_secure_game_password

# Docker Image Name (for CI/CD)
IMAGE_NAME=ghcr.io/your-username/your-repo-name
